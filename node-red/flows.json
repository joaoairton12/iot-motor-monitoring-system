    {
        "id": "c6ba53eb168e80ba",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Tratamento do payload",
        "func": "// ========================= NODE-RED FUNCTION =========================\n// Tratamento do payload CSV enviado pelo ESP32\n// Estrutura: 9 medições + 3 flags de validade + RSSI\n// =====================================================================\n\nconst raw = msg.payload.toString().trim().split(\",\");\n\n// ===== Validação =====\nif (raw.length !== 13) {\n    node.error(`[ERRO] Payload inválido. Recebidos ${raw.length}, esperado 13`);\n    return null;\n}\n\n// ===== Conversão =====\nconst d = raw.map(v => parseFloat(v));\n\n// ===== Validação de campo =====\nfunction campoInvalido(v) {\n    return Number.isNaN(v) || v === -1;\n}\n\n// ===== Conversão segura =====\nfunction valor(v) {\n    return campoInvalido(v) ? null : v;\n}\n\n// ======================== CAMPOS ========================\nlet fields = {\n\n    // ===== FASE R =====\n    tensao_r: valor(d[0]),\n    corrente_r: valor(d[1]),\n    potencia_r: valor(d[2]),\n\n    // ===== FASE S =====\n    tensao_s: valor(d[3]),\n    corrente_s: valor(d[4]),\n    potencia_s: valor(d[5]),\n\n    // ===== FASE T =====\n    tensao_t: valor(d[6]),\n    corrente_t: valor(d[7]),\n    potencia_t: valor(d[8]),\n\n    // ===== FLAGS DE VALIDADE =====\n    valido_r: d[9],\n    valido_s: d[10],\n    valido_t: d[11],\n\n    // ===== RSSI =====\n    rssi: Number.isFinite(d[12]) ? Math.round(d[12]) : 0\n};\n\n// ================= POTÊNCIA TOTAL =================\nif (\n    fields.potencia_r !== null &&\n    fields.potencia_s !== null &&\n    fields.potencia_t !== null\n) {\n    fields.potencia_total =\n        fields.potencia_r +\n        fields.potencia_s +\n        fields.potencia_t;\n} else {\n    fields.potencia_total = null;\n}\n\n// ================= TAGS =================\nlet tags = {\n    dispositivo: \"ESP32_TCC_UNIAVAN\",\n    tipo_carga: \"motor_eletrico\"\n};\n\n// ================= SAÍDA =================\nmsg.payload = [fields, tags];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
