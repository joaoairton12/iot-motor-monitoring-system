    {
        "id": "3b5f3d8b0943ac66",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "LWT",
        "func": "// =============================================\n// NODE-RED - STATUS LWT - Last Will and Testament\n// =============================================\n\nconst status = msg.payload.toString().trim().toLowerCase();\n\nlet fields = {\n    esp_online: (status === \"online\") ? 1 : 0\n};\n\nlet tags = {\n    dispositivo: \"ESP32_TCC_UNIAVAN\"\n};\n\nmsg.payload = [fields, tags];\n\nreturn msg;",
