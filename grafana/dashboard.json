        "uid": "afe0cgmznw45cb"
      },
      "description": "Indica se o ESP32 está online ou não. Se aparecer offline, provavelmente houve perda de comunicação ou o dispositivo está desligado.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "#ff001e",
                  "index": 1,
                  "text": "OFFLINE"
                },
                "1": {
                  "color": "#1eff00",
                  "index": 0,
                  "text": "ONLINE"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 3,
        "w": 3,
        "x": 15,
        "y": 0
      },
      "id": 16,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^esp_online ESP32_TCC_UNIAVAN$/",
          "values": false
        },
        "showPercentChange": false,
        "text": {},
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.3",
      "targets": [
        {
          "query": "from(bucket: \"monitoramento_motores\")\r\n  |> range(start: -24h)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"status_esp32\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"esp_online\")\r\n  |> filter(fn: (r) => r[\"dispositivo\"] == \"ESP32_TCC_UNIAVAN\")\r\n  |> last()",
          "refId": "A"
        }
      ],
      "title": "ESP32",
      "type": "stat"
    },
